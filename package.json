{
	"name": "webext-tools",
	"version": "3.0.0",
	"description": "Utility functions for Web Extensions",
	"keywords": [
		"extension",
		"chrome",
		"firefox",
		"safari",
		"web",
		"extensions",
		"execute",
		"function",
		"browser"
	],
	"repository": "fregante/webext-tools",
	"funding": "https://github.com/sponsors/fregante",
	"license": "MIT",
	"author": "Federico Brigante <me@fregante.com> (https://fregante.com)",
	"type": "module",
	"exports": {
		"./create-context-menu": {
			"types": "./distribution/create-context-menu.d.ts",
			"default": "./distribution/create-context-menu.js"
		},
		"./dev-tools-eval": {
			"types": "./distribution/dev-tools-eval.d.ts",
			"default": "./distribution/dev-tools-eval.js"
		},
		"./does-tab-exist": {
			"types": "./distribution/does-tab-exist.d.ts",
			"default": "./distribution/does-tab-exist.js"
		},
		"./get-extension-url": {
			"types": "./distribution/get-extension-url.d.ts",
			"default": "./distribution/get-extension-url.js"
		},
		"./get-tab-url": {
			"types": "./distribution/get-tab-url.d.ts",
			"default": "./distribution/get-tab-url.js"
		},
		"./query-tabs-by-url": {
			"types": "./distribution/query-tabs-by-url.d.ts",
			"default": "./distribution/query-tabs-by-url.js"
		},
		"./set-action-popup": {
			"types": "./distribution/set-action-popup.d.ts",
			"default": "./distribution/set-action-popup.js"
		},
		"./target": {
			"types": "./distribution/target.d.ts",
			"default": "./distribution/target.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"demo:build": "parcel build --no-cache",
		"demo:watch": "parcel watch --no-cache --no-hmr",
		"prepack": "tsc --sourceMap false",
		"test": "tsc --noEmit && xo && vitest run && npm run demo:build",
		"test:watch": "vitest",
		"watch": "tsc --watch"
	},
	"xo": {
		"envs": [
			"browser"
		],
		"globals": [
			"chrome"
		],
		"rules": {
			"unicorn/prefer-top-level-await": "off",
			"n/no-unsupported-features/node-builtins": "off"
		}
	},
	"dependencies": {
		"webext-detect": "^5.3.2",
		"webext-patterns": "^1.5.1",
		"webext-polyfill-kinda": "^1.0.2"
	},
	"devDependencies": {
		"@parcel/config-webextension": "^2.13.3",
		"@sindresorhus/tsconfig": "^7.0.0",
		"@types/chrome": "^0.0.299",
		"@types/jest": "^29.5.14",
		"@types/sinon-chrome": "^2.2.15",
		"jest-chrome": "^0.8.0",
		"parcel": "^2.13.3",
		"sinon-chrome": "^3.0.1",
		"typescript": "^5.7.3",
		"vitest": "^3.0.3",
		"xo": "^0.60.0"
	},
	"engines": {
		"node": ">=18"
	},
	"targets": {
		"main": false,
		"default": {
			"engines": {
				"browsers": "last 1 chrome version"
			},
			"source": "./source/demo/manifest.json",
			"distDir": "./.built/demo",
			"sourceMap": {
				"inline": true
			},
			"optimize": false
		}
	},
	"webExt": {
		"sourceDir": ".built/demo",
		"run": {
			"startUrl": [
				"https://example.com"
			]
		}
	}
}
